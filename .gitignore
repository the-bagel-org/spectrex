# SPHEREx ROI — .gitignore

# Rust build artifacts
/target/
Cargo.lock

# Python build artifacts
__pycache__/
build/
dist/
wheels/
*.egg-info
*.py[oc]
.venv/
uv.lock
docs/_build/
legacy/
**/.ipynb_checkpoints/

# Agent working state (not project deliverables)
.agents-workspace/
.worktrees/
.kilo
.opencode
.claude
AGENTS.md
.superpowers
docs/superpowers/

# Editor / OS
.DS_Store
.idea/
.vscode/
.git
.jj
*.swp

# Cache
.ruff_cache
notebooks/operator_cache.npz
notebooks/analysis_operator_cache.npz

# Test output scripts at repo root (not unittests/ directory)
/test_*.py
/test_*.sh
legacy/

# NeurIPS paper symlink (points to ../spectrex_neurips_2026_paper; not part of the wheel)
spectrex_neurips_2026_paper

# nbconvert collision-avoidance duplicates (e.g. foo_1.ipynb created alongside foo.ipynb)
notebooks/*_[0-9].ipynb
